# Binary EquaLab - Git Ignore
# Rule: ONLY README.md files are allowed. ALL other .md files are excluded.

# ===========================
# Markdown — ONLY README.md and .agent/ allowed
# ===========================
*.md
!README.md
!.agent/**/*.md
!.agent/*.md

# ===========================
# Private / Sensitive
# ===========================
.gemini/
*.private.*
*secrets*
*credentials*
*.env
.env.*

# ===========================
# Database / Scripts
# ===========================
*.sql
*.sh
*.ps1
*.bat

# ===========================
# Test scripts / Temp results (keep only in tests/ folder)
# ===========================
test_*.py
result_*.txt

# ===========================
# Python
# ===========================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.pytest_cache/
.coverage
htmlcov/
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# ===========================
# Node / Web
# ===========================
node_modules/
.DS_Store
.env.local
.env.development.local
.env.test.local
.env.production.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ===========================
# IDEs
# ===========================
.idea/
.vscode/
*.swp
*.swo

